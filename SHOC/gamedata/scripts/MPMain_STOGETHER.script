	local str = type(o) ~= "string" and (o.section_name and o:section_name() or o.section and o:section()) or o
	local d = ini_sys:r_string(str, "kind")
	if d == "i_medical" then
		local ptrs = {
			["glucose"] = true,
			["morphine"] = true,
			["analgetic"] = true,
			["rebirth"] = true,
			["adrenaline"] = true,
			["stimpack"] = true,
