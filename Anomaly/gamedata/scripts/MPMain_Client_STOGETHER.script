local GameManager = SteamGameManager()
function Patch()
    log("[Client] Patching game for some things...")
	_G.alife_create = function (sec, pos, lid, gid, id, state)
		if id or string.match(sec, "level_changer") then
            return alife_create_local(sec, pos, lid, gid, id, state)
        end
	end
	death_manager.create_release_item = function (npc)
		if not npc then return end
		local death_dropped = se_load_var(npc:id(), npc:name(), "death_dropped")
        if death_dropped then return end
        se_save_var(npc:id(), npc:name(), "death_dropped", true)
		npc:iterate_inventory(function (_, itm)
			alife_release(itm)
		end, nil)
		GameManager:OnIStashOpen(alife_object(npc:id()))
	end
	local temp = {}
	treasure_manager.try_spawn_treasure = function (box)
		local id = box:id()
		if temp[id] then return end
		temp[id] = true
		box:iterate_inventory_box(function (_, itm)
            alife_release(itm)
        end, nil)
		GameManager:OnIStashOpen(alife_object(id))
	end
