	pda.npc_on_net_spawn = function(npc, se_obj)
		if not se_obj then return end
		se_save_var(se_obj.id, se_obj:name(), "last_seen_level", level.name())
		se_save_var(se_obj.id, se_obj:name(), "last_seen_time", game.get_game_time())
	end
	dialogs_axr_companion.become_actor_companion = function(actor, npc)
		local npc = dialogs.who_is_npc(actor,npc)
		local squad = get_object_squad(npc)
		GameManager:OnIWantCompanion(alife_object(npc:id()))
		if not (squad) then
			return
		end
		axr_companions.companion_squads[squad.id] = squad
		SIMBOARD:assign_squad_to_smart(squad, nil)
		for k in squad:squad_members() do
			local member = db.storage[k.id] and db.storage[k.id].object
			if ( member and member:alive() ) then
				axr_companions.add_to_actor_squad(member)
			end
		end
	end
