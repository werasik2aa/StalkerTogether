	ui_sleep_dialog.dream_callback = function()
		local shelf = ui_sleep_dialog
		if shelf.GUI.forced then
			level.add_cam_effector("camera_effects\\surge_01.anm", 10, false, "ui_sleep_dialog.dream_callback2")
		else
			level.add_cam_effector("camera_effects\\sleep.anm", 10, false, "ui_sleep_dialog.dream_callback2")
		end
		local hours = shelf.GUI.forced or shelf.GUI.time_track:GetIValue()
		--printf("dream_callback hours=%s",hours)
		if IIsHost() then
			level.change_game_time(0,hours,0)
		end
		db.actor.power = 1
		SendScriptCallback("actor_on_sleep",hours)
	end
	alife_storage_manager.get_state().stop_respawns = true
	xr_effects.setup_companion_task = function(actor,npc,p)
		local sq_sec = p[1]
		local smrt_name = p[2]
		local var_id = p[3]
		local is_hostage = p[5]
		local var = var_id and var_id ~= "nil" and load_var(db.actor,var_id)
		local smart_id = var and var.smart_id
		local smart = smart_id and alife_object(smart_id) or smrt_name and smrt_name ~= "nil" and SIMBOARD.smarts_by_names[smrt_name]
		--xQd
		if _G.WARFARE and (not smrt_name or smrt_name == "false") and (not is_hostage or is_hostage == "false") then
			for sname, sm in pairs(SIMBOARD.smarts_by_names) do
				if sm.is_on_actor_level == true and sm.dist_to_actor <= 50 then
					smart = sm
					save_var(db.actor,"warfare_escort_task_smart", sname)
					break
				end
			end
		end
		--xQd end
		if not (smart) then
			printe("! setup_companion_task: no smart found! %s", smart_id or smrt_name)
			return
		end
		if not (ini_sys:section_exist(sq_sec)) then
			printe("! setup_companion_task: Trying to setup companion squad with a non-existent section!")
			return
		end
	end
	function sim_board.simulation_board:create_squad(spawn_smart, sq_id)
		local squad_id = tostring(sq_id)
		local squad = alife_create(squad_id,spawn_smart.position,	spawn_smart.m_level_vertex_id,spawn_smart.m_game_vertex_id)
		if not squad then return end
		squad:create_npc(spawn_smart)
		self:assign_squad_to_smart(squad, spawn_smart.id)

		local sim = alife()
		for k in squad:squad_members() do
			local se_obj = k.object or k.id and sim:object(k.id)
			if (se_obj) then
				SIMBOARD:setup_squad_and_group(se_obj)
				SendScriptCallback("squad_on_npc_creation",squad,se_obj,spawn_smart)
			end
		end
		return squad
	end
	function sim_board.simulation_board:create_squad_at_named_location(loc_name, squad_id) -- tdef
	
		-- if not (ini_file('misc\\squad_descr.ltx'):section_exist(squad_id)) then
		if not (ini_sys:section_exist(squad_id)) then
			callstack()
			printf("create_squad_at_named_location: squad section does not exist in misc\\squad_descr.ltx: %s",squad_id)
			return
		end
		
		local str = utils_data.read_from_ini(ini_file("named_locations.ltx"),loc_name,'position')
		
		if not str then 
			callstack()
			printf('create_squad_at_named_location: named location not defined in named_locations.ltx: %s',loc_name) 
			return 
		end
		
		-- printf('%s: %s',loc_name, str)
		
		local function str_explode_num(str,sep,plain)
			if not (sep ~= "" and string.find(str,sep,1,plain)) then
				return { str }
			end
			local t = {}
			local size = 0
			for s in str:gsplit(sep,plain) do 
				size = size + 1
				t[size] = tonumber(s)
				if not t[size] then
					printf("str_explode_num: warning: %s couldn't be parsed as number", s)
				end
			end
			return t
		end
		local data = str_explode_num(str,',')
		
		-- for k,v in pairs(data) do
			-- printf('data[%s] = %s (%s)',k, v, type(v))
		-- end
		
		local pos = vector():set(data[1], data[2], data[3])
		
		local squad = alife_create(squad_id, pos,	data[4], data[5])
		if not squad then return end
		squad:create_npc(nil, pos, data[4], data[5])
	
		local sim = alife()
		for k in squad:squad_members() do
			local se_obj = k.object or k.id and sim:object(k.id)
			if (se_obj) then
				SIMBOARD:setup_squad_and_group(se_obj)
				-- Alundaio
				SendScriptCallback("squad_on_npc_creation",squad,se_obj)
				-- Alundaio
			end
		end
		return squad
	end
