function OnPlayerCustomAnimation(PlayerNetID, Animation, Item, Delay, Force, obj_id)
    log("[Client] OnPlayerCustomAnimation")
    log("[Client] NET PlayerID: "..tostring(PlayerNetID))
    log("[Client] Animation: "..tostring(Animation))
    log("[Client] Section: "..tostring(Item))
    log("[Client] Delay: "..tostring(Delay))
    log("[Client] Force: "..tostring(Force))
    if obj_id == 65535 then return end
    CreateTimeEvent(obj_id, "DEATTACH_FUCK_FROM_ASS", Delay, function ()
        local obj = level.object_by_id(obj_id)
        if obj then
            log("[Client] Deattach spawned item: "..tostring(obj_id))
            _ = obj.enable_attachable_item and obj:enable_attachable_item(false)
            local sobj = alife_object(obj_id)
            if sobj then alife():release_local(sobj) end
        end
        return true
    end)
end

