function OnConnectFail()
    log("[Client] Server not found...")
end
function OnConnected(server_name, MyRemoteNetID)
    log("[Client] Server found...")
    log("[Client] Lua ServerName: "..tostring(server_name))
    log("[Client] Lua MyID: "..tostring(MyRemoteNetID))
    if level.present() then
        log("[Client] Stage 3 : Sending our player data")
        local mss = "Connected to server as"
        if IIsHost() then
            news_manager.send_tip(db.actor, mss.." host!", nil, "nano", 20000)
        else
            news_manager.send_tip(db.actor, mss.." client!", nil, "nano", 20000)
        end
        MPMain_STOGETHER.GameManager:OnILoaded()
    else
        MPMain_STOGETHER.WaitMe = 99
    end
end

function OnPlayerConnected(PlayerNetID, SE_OBJ, nickname, level_name)
    if not SE_OBJ or type(SE_OBJ) == "number" then return end
    log("[Client] On Player Connected")
    log("[Client] ObjectID: "..(SE_OBJ and tostring(SE_OBJ.id) or "NOT_SPAWNED"))
    log("[Client] NetID: "..tostring(PlayerNetID))
    if db.actor then
        local mss = "Player "..tostring(nickname).." connected to level: "..tostring(level_name)
        news_manager.send_tip(db.actor, mss, nil, "nano", 20000)
    end
    if SE_OBJ then
        log("[Client] Adding map point. Adding to list for player marks handler")
        MPPlayerMarker_STOGETHER.AddEntity(SE_OBJ.id, nickname)
    end
end
function OnPlayerChangedLevel(PlayerNetID, SE_OBJ, NickName)
    if not SE_OBJ then return end
    log("[Client] On Player Changed Level")
    log("[Client] NetID: "..tostring(PlayerNetID))
    if db.actor then
        local mss = "Player "..tostring(NickName).." changing level"
        news_manager.send_tip(db.actor, mss, nil, "nano", 20000)
    end
    if SE_OBJ then
        log("[Client] Removing map point. Removing player from marks handler")
        MPPlayerMarker_STOGETHER.RemoveEntity(SE_OBJ.id)
    end
end
function OnPlayerDisconnected(PlayerNetID, SE_ID, nickmame)
    log("[Client] On Player Disconnected")
    log("[Client] NetID: "..tostring(PlayerNetID))
    if db.actor then
        local mss = "Player "..tostring(nickmame).." disconnected"
        news_manager.send_tip(db.actor, mss, nil, "nano", 20000)
    end
    if SE_ID == 0 then return end
    log("[Client] Removing map point. Removing player from marks handler")
    MPPlayerMarker_STOGETHER.RemoveEntity(SE_ID)
end

