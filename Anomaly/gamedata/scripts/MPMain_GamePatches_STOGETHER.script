    bind_campfire.campfire_go_off = function(cf, obj)
        local cf = cf or get_nearby_campfire(dist_cf,true)
        if cf and (cf:is_on()) then
            actor_effects.play_item_fx("matches_script")
            cf:turn_off()
            GameManager:OnIInteract(alife_object(obj:id()), 22)
        end
    end
    bind_campfire.campfire_go_on = function(obj, cf)
        local dist_cf = 2
        local cf = cf or bind_campfire.get_nearby_campfire(dist_cf, true)
        if (not cf) then
            return
        end
        if (cf:is_on()) then
            return
        end
        if bind_campfire.rain_pass() then
            actor_effects.play_item_fx("matches_script")
            xr_sound.set_sound_play(AC_ID,"inv_matches")
            cf:turn_on()
            GameManager:OnIInteract(alife_object(obj:id()), 2)
        else
            actor_effects.play_item_fx("matches_script")
            actor_menu.set_msg(1, game.translate_string("st_fail"),3)
        end
    end
    bind_campfire.actor_on_item_use = function(obj, cfo, cf)
        local sec = obj:section()
        if (sec == "matches") or (sec == "box_matches") then
            bind_campfire.campfire_go_on(cfo, cf)
            utils_item.discharge(obj)
        end
    end
    bind_campfire.use_campfire = function(actor,zone,p) -- called from game_tutorials.xml
        local pos = db.actor:position()
        for id, binder in pairs(bind_campfire.campfires_all) do
            if (binder and binder.campfire) then
                if (pos:distance_to_sqr(binder.object:position()) <= 2) then
                    if (binder.campfire:is_on()) then 
                        bind_campfire.campfire_go_off(binder.campfire, binder.object)
                    else
                        local obj_item = db.actor:object("matches") or db.actor:object("box_matches")
                        if obj_item then
                            bind_campfire.actor_on_item_use(obj_item, binder.object, binder.campfire)
                        else
                            actor_menu.set_msg(1, game.translate_string("st_ui_campfire_prereq"),3)
                        end
                    end
                end
            end
        end
    end
    itms_manager.use_guitar = function(obj)
        local n = math.random(28)
        local snd = sound_object("music\\guitar_" .. tostring(n))
        if (not snd) then return end
        local period = snd:length()
