    trans_outfit.transparent_gg = function ()
        local range1 = 80
        local outfit_in_slot = db.actor:item_in_slot(7)
        if not db.actor then return end
        if outfit_in_slot and trans_outfit.ReadOutfitBlindnessKoeff(outfit_in_slot:section()) > 0.0 then
            range1 = trans_outfit.ReadOutfitBlindnessKoeff(outfit_in_slot:section())
        end
        for _, t in pairs(db.storage) do
            if t and t.object and IsStalker(t.object) and not IsActor(t.object) then
                local dist_act_npc = db.actor:position():distance_to(t.object:position())
                if dist_act_npc <= 120 then
                    t.object:set_range(range1)
                else
                    t.object:set_range(80)
                end
            end
        end
    end
    txr_mines.EXPLOSIVE_SECTION_LOOKUP = {
        mine_new 	= 'mine_new_blow',
        ied_rpg_new = 'rpg_new_blow',
        ied_new 	= 'ied_new_blow',
    }
    txr_mines.FX_BY_SECTION = {
        mine_new 	= 'mine',
        ied_rpg_new = 'ied_rpg',
        ied_new 	= 'ied',
    }
    function txr_mines.plant_bomb(obj, mode, delay)
        local MIN_FORGET_TIME 	= 60*10
        local MAX_FORGET_TIME 	= 60*30
        local FUSE_TIME 		= 5

        printf('plant_bomb(%s,%s,%s)', obj:name(), mode, delay)
        local now = txr_mines.tss()
        local used_section = obj:section()
        local used_id = obj:id()
        local planted_section = txr_mines.EXPLOSIVE_SECTION_LOOKUP[used_section]
        printf('planted_section = %s', planted_section)
        local cd = device().cam_dir
        -- local r = level.get_target_dist()
        -- local lvid = level.vertex_in_direction(level.vertex_id(device().cam_pos),device().cam_dir,r)
        -- local p = level.vertex_position(vid)
        local ap = db.actor:position()
        local pp = vector():set(ap.x + cd.x, ap.y + 0.1, ap.z + cd.z)
        local vid = level.vertex_id(pp)
        pp = level.vertex_position(vid)
        alife_create_awaite(function (planted_se)
            printf('creating %s at', planted_se:name())
            printf('%s,%s,%s,%s,%s',ap.x,ap.y,ap.z,db.actor:level_vertex_id(),db.actor:game_vertex_id())
            printf('actual position')
            printf('%s,%s,%s,%s,%s', planted_se.position.x,planted_se.position.y,planted_se.position.z,planted_se.m_level_vertex_id,planted_se.m_game_vertex_id)
            local planted_id = planted_se.id
            
            printf('try FX')
            _ = txr_mines.FX_BY_SECTION[used_section] and actor_effects.play_item_fx(txr_mines.FX_BY_SECTION[used_section])
            
            printf('check witnesses')
            local witnesses = {}
            for i in pairs(db.OnlineStalkers) do
                local id = db.OnlineStalkers[i]
                local npc = level.object_by_id(id)
                if npc and IsStalker(npc) and npc:alive() then
                    if npc:see(db.actor) then
                        printf('%s saw player plant %s', npc:name(), planted_se:name())
                        witnesses[id] = now + math.random(MIN_FORGET_TIME, MAX_FORGET_TIME)*level.get_time_factor()
                    end
                end
            end
            
            printf('save mine data')
            txr_mines._mines[planted_id] = {
                exp_time = now + (delay or FUSE_TIME) * level.get_time_factor(),
                mode = mode,
                witnesses = witnesses,
                -- level = level.name(),
                active = true
                -- blast_radius = ini_sys:r_float_ex(planted_section,"blast_r")
            }
            
            
            printf('create release event')
            CreateTimeEvent(0,"release_planted_mine",0, txr_mines.release_item, used_id)
        end, planted_section, ap, db.actor:level_vertex_id(), db.actor:game_vertex_id())
    end
    level_input.action_quick_load = function (dik,bind)
		return true
	end
    axr_turn_on_campfire.eval_reset = function(st)
        if (st.selected_id) then
            axr_turn_on_campfire.already_selected[st.selected_id] = nil
            st.selected_id = nil
        end
        st.vid = nil
        st.__stimer = nil
        st.camp = nil
        st.state = nil
        if (st.npc and state_mgr.get_state(st.npc) == "light_campfire") then
            state_mgr.set_state(st.npc,"guard")
        end
        return false
    end
    axr_turn_on_campfire.light_campfire = function(npc)
        local id = npc:id()
        local st = db.storage[id] and db.storage[id].turn_on_campfire
        local camp = st and st.selected_id and level.object_by_id(st.selected_id)
        if not camp then
            return axr_turn_on_campfire.eval_reset(st)
        end
        local CFZone = camp:get_campfire()
        if not CFZone then
            return axr_turn_on_campfire.eval_reset(st)
        end
        if render_get_dx_level() == 655361 then
            camp:enable_anomaly()
        end
        if CFZone:is_on() then
            return axr_turn_on_campfire.eval_reset(st)
        end
        CFZone:turn_on()
        if IIsHost() then
            GameManager:OnIInteract(alife_object(st.selected_id), 2)
        end
        axr_turn_on_campfire.eval_reset(st)
    end
    ui_inventory.snd_drop_item = sound_object([[interface\inv_drop]])
    function ui_inventory.UIInventory:Action_Drop(obj, bag)
        obj = self:CheckItem(obj,"Action_Drop")
        db.actor:drop_item(obj)
        GameManager:OnIDrop(alife_object(obj:id()))
        self:PlaySND(ui_inventory.snd_drop_item)
    end
    function ui_inventory.UIInventory:Action_Drop_All(obj, bag)
        obj = self:CheckItem(obj,"Action_Drop_All")
        local ci = self.CC[bag]:GetCell_ID(obj:id())
        for id,_ in pairs(ci.childs) do
            local obj_c = level.object_by_id(id)
            if obj_c then
                db.actor:drop_item(obj_c)
                GameManager:OnIDrop(alife_object(obj_c:id()))
            end
        end
        db.actor:drop_item(obj)
        GameManager:OnIDrop(alife_object(obj:id()))
        self:PlaySND(ui_inventory.snd_drop_item)
    end
    task_status_functor.actor_has_fetch_item = function(tsk,task_id)
        local actor = db.actor
        local section = actor and load_var(actor,task_id.."_fetch")
        if not section then
            return
        end
        local item = section and actor:object(section)
        if item then
            if (task_id == "esc_2_12_stalker_nimble_task_1" or task_id == "jup_b220_trapper_task_3") then 
                if (item:condition() >= 0.9) then
                    tsk.stage = 1
                elseif IIsHost() then
                    tsk.stage = 0
                end
            else
                local count = load_var(actor,task_id.."_fetch_count")
                if (count and count > 1) then
                     local cnt = utils_item.get_amount(db.actor, section, 1)
                    if (cnt >= count) then
                        tsk.stage = 1
                    elseif IIsHost() then
                        tsk.stage = 0
                    end
                    return
                end
                tsk.stage = 1 -- should never happen but in such case let player finish quest for free
            end
        elseif section and string.find(section, "af_") then
            if actor:object(section .. "_af_aam")
            or actor:object(section .. "_af_iam")
            or actor:object(section .. "_af_aac")
            or actor:object(section .. "_lead_box")
            then
                tsk.stage = 1
            elseif IIsHost() then
                tsk.stage = 0
            end
        elseif IIsHost() then
            tsk.stage = 0
        end
    end
    function xr_camper.action_patrol:reset_scheme()
        --utils_data.debug_write("action_patrol:reset_scheme")
        if not self.move_mgr then
            self.move_mgr = move_mgr.move_mgr(self.object)
        end
        state_mgr.set_state(self.object, "patrol")
        self.a.signals = {}
        self.a.scan_table = {}
        if self.a.sniper == true then
            self.move_mgr:reset(self.a.path_walk,utils_obj.path_parse_waypoints(self.a.path_walk),nil,nil,nil,self.a.suggested_state,{obj=self,func=self.process_point})
            local path = self.a.path_look and patrol(self.a.path_look)
            if path ~= nil then
                for k = 0, path:count() - 1 do
                    for i = 0, 31 do
                        if path:flag(k, i) then
                            if self.a.scan_table[i] == nil then
                                self.a.scan_table[i] = {}
                            end
                            local t = self.a.scan_table[i]
                            t[#t+1] = {key = k, pos = path:point(k)}
                        end
                    end
                end
            end
            if (self.object:sniper_update_rate() == false) then
                self.object:sniper_update_rate(true)
            end
        else
            self.move_mgr:reset(self.a.path_walk, utils_obj.path_parse_waypoints(self.a.path_walk), self.a.path_look, utils_obj.path_parse_waypoints(self.a.path_look), nil, self.a.suggested_state, { obj = self, func = self.process_point})
            if self.object:sniper_update_rate() == true then
                self.object:sniper_update_rate(false)
            end
        end
        self.a.last_look_point = nil
        self.a.cur_look_point = nil
        self.a.scan_begin = nil
    end
    xr_effects.game_disconnect = function (actor, npc)
        if IIsHost() then
            MPMain_STOGETHER.ServerSOSOCK:CloseListenSocket()
        else
            MPMain_STOGETHER.ClientSocks:Disconnect()
        end
		exec_console_cmd("disconnect")
	end
    simulation_objects.get_server_entity = function(id)
        for i = 1, simulation_objects.object_registry_size do
            local se_obj = simulation_objects.object_registry[i]
            if se_obj and se_obj.id == id then
                return se_obj
            end
        end
    end
end